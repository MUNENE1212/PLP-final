# Environment
NODE_ENV=development

# Server Configuration
PORT=5000
API_VERSION=v1

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/dumuwaks
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/dumuwaks?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Generate secure secrets using:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run twice to generate two different secrets for JWT_SECRET and JWT_REFRESH_SECRET
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Redis Configuration (for caching and sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For Redis Cloud:
# REDIS_URL=redis://username:password@redis-cloud-url:port

# Cloudinary Configuration (PRIMARY MEDIA STORAGE)
# Setup Instructions:
# 1. Sign up for Cloudinary at https://cloudinary.com/
# 2. Get your Cloud Name, API Key, and API Secret from the dashboard
# 3. Add these credentials below:
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@dumuwaks.com

# SMS Configuration (Africa's Talking)
AT_USERNAME=your-username
AT_API_KEY=your-api-key
AT_SENDER_ID=DUMUWAKS

# Twilio Configuration (Alternative SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Gateways

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox

# M-Pesa Callback URLs
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mpesa/callback

# M-Pesa Webhook URLs (for escrow integration)
MPESA_STK_CALLBACK_URL=https://yourdomain.com/api/v1/mpesa/webhooks/stk-callback
MPESA_B2C_CALLBACK_URL=https://yourdomain.com/api/v1/mpesa/webhooks/b2c-callback
MPESA_B2C_QUEUE_TIMEOUT_URL=https://yourdomain.com/api/v1/mpesa/webhooks/timeout
MPESA_VALIDATION_URL=https://yourdomain.com/api/v1/mpesa/webhooks/validation
MPESA_CONFIRMATION_URL=https://yourdomain.com/api/v1/mpesa/webhooks/confirmation

# M-Pesa Security (CRITICAL for production)
# Generate a strong secret and configure in Safaricom portal
# This validates that callbacks are genuinely from Safaricom
MPESA_CALLBACK_SECRET=your-mpesa-callback-secret-from-safaricom-portal

# Set to false in sandbox/development, true in production
MPESA_VALIDATE_IPS=false

# M-Pesa B2C Configuration (for payouts to technicians)
MPESA_INITIATOR_NAME=your-initiator-name
MPESA_SECURITY_CREDENTIAL=your-security-credential

# Allow sandbox in production (for testing only - NEVER set to true in real production)
ALLOW_SANDBOX_IN_PROD=false

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Firebase Admin (for push notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email
# Or path to service account JSON
FIREBASE_SERVICE_ACCOUNT=./config/firebase-service-account.json

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Agora (Video Calling)
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# KYC Service (Smile Identity)
SMILE_PARTNER_ID=your-partner-id
SMILE_API_KEY=your-api-key
SMILE_CALLBACK_URL=https://yourdomain.com/api/v1/kyc/callback

# AI Configuration (Cohere for DumuBot)
COHERE_API_KEY=your-cohere-api-key
COHERE_MODEL=command-r-plus-08-2024

# Client URLs (for CORS and redirects)
CLIENT_WEB_URL=http://localhost:3000
CLIENT_MOBILE_URL=dumuwaks://

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Admin Configuration
ADMIN_EMAIL=admin@dumuwaks.com
ADMIN_PASSWORD=change-this-strong-password

# Rate Limiting
# DO NOT disable rate limiting in production
# DISABLE_RATE_LIMIT is for development/testing only
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=5

# Session Configuration
SESSION_SECRET=your-session-secret-change-this
SESSION_COOKIE_MAX_AGE=86400000

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

# Message Encryption
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# Feature Flags
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=true
ENABLE_AI_MODERATION=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Maintenance Mode
MAINTENANCE_MODE=false

# API Documentation
ENABLE_API_DOCS=true
API_DOCS_PATH=/api-docs

# Monitoring (New Relic, Datadog, etc.)
NEW_RELIC_LICENSE_KEY=your-new-relic-key
NEW_RELIC_APP_NAME=DumuWaks-Backend

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Timezone
TZ=Africa/Nairobi
